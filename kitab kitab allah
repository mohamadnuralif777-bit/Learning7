<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Beriman kepada Kitab-kitab Allah SWT</title>
  <style>
    :root {
      --ink: #18232b;
      --muted: #66737b;
      --paper: #fffef9;
      --ivory: #fff8e8;
      --linen: #f6edd8;
      --emerald: #12725f;
      --deep-emerald: #0c4e48;
      --teal: #25899a;
      --saffron: #e5aa2f;
      --amber: #f2ca63;
      --coral: #d96a55;
      --rose: #a84f65;
      --indigo: #445389;
      --leaf: #6d9855;
      --sky: #cce8ee;
      --line: #dfd2b8;
      --soft-teal: #e8f6f4;
      --soft-gold: #fff3cc;
      --soft-rose: #fff0ec;
      --shadow: 0 18px 48px rgba(24, 35, 43, .13);
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      color: var(--ink);
      background:
        linear-gradient(90deg, rgba(18, 114, 95, .06) 0 1px, transparent 1px 42px),
        linear-gradient(180deg, rgba(229, 170, 47, .07) 0 1px, transparent 1px 42px),
        linear-gradient(135deg, rgba(204, 232, 238, .7), rgba(255, 248, 232, .8) 34%, rgba(255, 240, 236, .72) 68%, rgba(232, 246, 244, .88)),
        var(--paper);
      font-family: "Segoe UI", Arial, sans-serif;
      font-size: 14.8px;
      line-height: 1.68;
    }

    @page {
      size: A4;
      margin: 17mm 17mm 19mm;
    }

    @media print {
      body {
        background: #fff;
      }

      .page,
      .chapter,
      .section-page {
        break-after: page;
      }

      .no-break,
      .dalil,
      .mini-card,
      .source-card,
      .term-card,
      .check-card,
      .activity-box {
        break-inside: avoid;
      }

      a {
        color: inherit;
        text-decoration: none;
      }
    }

    .page,
    .chapter,
    .section-page {
      min-height: 260mm;
      position: relative;
      border-top: 7px solid rgba(18, 114, 95, .28);
    }

    .cover {
      min-height: 297mm;
      margin: -17mm;
      padding: 22mm 20mm 18mm;
      position: relative;
      overflow: hidden;
      color: #fff8df;
      background:
        linear-gradient(120deg, rgba(255,255,255,.54) 0 15%, transparent 15% 30%, rgba(255,255,255,.22) 30% 31%, transparent 31%),
        linear-gradient(158deg, #fff1be 0%, #f0bd46 22%, #158171 23%, #0f5953 49%, #445389 50%, #d96a55 72%, #fff2cf 100%);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .cover::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(45deg, rgba(255,255,255,.08) 0 2px, transparent 2px 18px),
        linear-gradient(90deg, transparent 0 10%, rgba(12,78,72,.32) 10% 11%, transparent 11% 89%, rgba(12,78,72,.28) 89% 90%, transparent 90%);
      opacity: .8;
    }

    .cover-title,
    .cover-art,
    .cover-footer {
      position: relative;
      z-index: 1;
    }

    .cover-title {
      max-width: 172mm;
      padding: 14px 15px 16px;
      border-left: 5px solid rgba(255, 221, 130, .92);
      border-radius: 8px;
      background:
        linear-gradient(90deg, rgba(7, 42, 39, .72) 0%, rgba(7, 42, 39, .48) 68%, rgba(7, 42, 39, .05) 100%);
      box-shadow: 0 16px 38px rgba(7, 31, 36, .24);
      backdrop-filter: blur(2px);
    }

    h1,
    h2,
    h3,
    h4 {
      margin: 0 0 12px;
      color: #16252d;
      font-family: "Trebuchet MS", "Segoe UI", Arial, sans-serif;
      line-height: 1.17;
      font-weight: 850;
      letter-spacing: 0;
    }

    h1 {
      max-width: 160mm;
      color: #fffdf2;
      font-size: 52px;
      text-shadow: 0 3px 0 rgba(12, 44, 43, .5), 0 10px 24px rgba(0, 0, 0, .34);
    }

    h2 {
      font-size: 31px;
      margin-top: 6px;
    }

    h3 {
      font-size: 21px;
      margin-top: 20px;
    }

    h4 {
      color: #1c645c;
      font-size: 16.5px;
      margin-top: 16px;
    }

    p {
      margin: 0 0 11px;
    }

    .kicker,
    .label,
    .toc,
    .chapter-ribbon,
    .chapter-number,
    .caption,
    .ref,
    .cover-badges span,
    .book-mark,
    .book-meta {
      font-family: "Trebuchet MS", "Segoe UI", Arial, sans-serif;
    }

    .kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 13px;
      padding: 6px 11px;
      color: #103b38;
      background: rgba(255, 251, 238, .88);
      border: 1px solid rgba(255, 255, 255, .66);
      border-radius: 999px;
      font-size: 11px;
      font-weight: 850;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .kicker::before {
      content: "";
      width: 9px;
      height: 9px;
      border-radius: 2px;
      background: linear-gradient(135deg, var(--emerald), var(--saffron));
      transform: rotate(45deg);
    }

    .cover .subtitle {
      max-width: 134mm;
      margin-top: 12px;
      color: #fff6d7;
      font-family: "Trebuchet MS", "Segoe UI", Arial, sans-serif;
      font-size: 20px;
      line-height: 1.45;
      text-shadow: 0 2px 10px rgba(0, 0, 0, .34);
    }

    .cover-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 18px;
    }

    .cover-badges span {
      display: inline-flex;
      align-items: center;
      min-height: 29px;
      padding: 6px 10px;
      border: 1px solid rgba(255, 255, 255, .42);
      border-radius: 999px;
      background: rgba(255, 254, 249, .76);
      color: #173f3b;
      font-size: 12px;
      font-weight: 800;
    }

    .cover-art {
      width: 100%;
      height: 148mm;
      margin: 9mm 0 3mm;
      filter: drop-shadow(0 22px 34px rgba(0,0,0,.22));
    }

    .cover-footer {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      align-items: end;
      color: #fff6df;
      font-size: 12.5px;
    }

    .cover-footer strong {
      display: block;
      color: #fff;
      font-size: 14px;
      margin-bottom: 4px;
    }

    .book-mark {
      width: 45mm;
      padding: 9px 11px;
      border-left: 3px solid var(--amber);
      background: rgba(8, 42, 40, .58);
    }

    .label {
      display: inline-block;
      margin-bottom: 8px;
      color: var(--emerald);
      font-size: 11px;
      font-weight: 850;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .lead {
      color: #40525b;
      font-size: 16px;
      line-height: 1.58;
      margin-bottom: 16px;
    }

    .book-meta {
      margin-top: 18px;
      padding-top: 16px;
      border-top: 3px double var(--line);
      color: var(--muted);
      font-size: 13px;
    }

    .toc {
      list-style: none;
      padding: 0;
      margin: 18px 0 0;
      border-top: 1px solid var(--line);
    }

    .toc li {
      display: flex;
      justify-content: space-between;
      gap: 18px;
      padding: 8px 0;
      border-bottom: 1px solid var(--line);
    }

    .toc a {
      color: inherit;
      text-decoration: none;
    }

    .toc .toc-sub {
      padding-left: 18px;
      color: var(--muted);
      font-size: 13.4px;
    }

    .chapter-head {
      display: grid;
      grid-template-columns: 1fr 73mm;
      gap: 12mm;
      align-items: center;
      margin-bottom: 18px;
      padding: 14px 14px 16px;
      border: 1px solid #d8caa8;
      border-left: 9px solid var(--emerald);
      border-bottom: 4px solid var(--saffron);
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(232, 246, 244, .96) 0%, rgba(255, 243, 204, .95) 55%, rgba(255, 240, 236, .94) 100%);
      box-shadow: 0 10px 28px rgba(24, 35, 43, .08);
    }

    .chapter-head h2 {
      color: #17313a;
    }

    .chapter-number {
      display: inline-grid;
      place-items: center;
      width: 30px;
      height: 30px;
      margin-right: 8px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--emerald), var(--indigo));
      color: #fff;
      font-size: 13px;
      vertical-align: 4px;
    }

    .note,
    .source-note,
    .activity-box,
    .summary-box,
    .warning-box {
      margin: 14px 0;
      padding: 13px 15px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: linear-gradient(135deg, #fff9ea, #fffef9);
    }

    .source-note {
      background: linear-gradient(135deg, var(--soft-teal), #fffef9);
      border-color: #c6e4df;
    }

    .warning-box {
      background: linear-gradient(135deg, var(--soft-rose), #fff8e5);
      border-color: #edc8bf;
    }

    .summary-box {
      border-top: 5px solid var(--leaf);
      background: linear-gradient(135deg, #f0f8ea, #fffef9);
    }

    .note strong,
    .source-note strong,
    .warning-box strong,
    .summary-box strong,
    .activity-box strong {
      color: #155c54;
    }

    .dalil {
      margin: 14px 0 16px;
      padding: 14px 15px 12px;
      border-left: 6px solid var(--emerald);
      border-radius: 0 8px 8px 0;
      background:
        linear-gradient(90deg, rgba(18, 114, 95, .16) 0%, rgba(255, 243, 204, .72) 58%, #fffef9 100%);
      box-shadow: 0 8px 22px rgba(18, 114, 95, .08);
    }

    .dalil.hadith {
      border-left-color: var(--rose);
      background:
        linear-gradient(90deg, rgba(168, 79, 101, .16) 0%, rgba(255, 243, 204, .76) 58%, #fffef9 100%);
    }

    .dalil-title {
      margin-bottom: 6px;
      color: #123d39;
      font-family: "Trebuchet MS", "Segoe UI", Arial, sans-serif;
      font-size: 15px;
      font-weight: 850;
    }

    .dalil .arabic {
      direction: rtl;
      unicode-bidi: isolate;
      margin: 8px 0 10px;
      color: #12342f;
      font-family: "KFGQPC HAFS Uthmanic Script", "KFGQPC Uthmanic Script HAFS", "UthmanicHafs1 Ver18", "Traditional Arabic", "Amiri", "Scheherazade New", serif;
      font-size: 23px;
      line-height: 2.05;
      text-align: right;
    }

    .meaning {
      color: #344852;
    }

    .translation {
      margin: 8px 0;
      padding: 9px 11px;
      border-top: 1px solid rgba(18, 114, 95, .2);
      border-bottom: 1px solid rgba(18, 114, 95, .14);
      background: rgba(255, 255, 255, .5);
      color: #2d3f49;
      font-size: 13.8px;
    }

    .translation strong {
      color: #155c54;
    }

    .ref {
      margin-top: 7px;
      color: var(--emerald);
      font-size: 12.5px;
      font-weight: 850;
    }

    .grid-two {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin: 14px 0;
    }

    .grid-three {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
      margin: 14px 0;
    }

    .mini-card,
    .source-card,
    .term-card,
    .check-card {
      min-height: 100%;
      padding: 13px 14px;
      border: 1px solid #ded0b2;
      border-radius: 8px;
      background: linear-gradient(180deg, #fffef9 0%, #fff6e3 100%);
      box-shadow: 0 8px 22px rgba(24, 35, 43, .06);
    }

    .mini-card:nth-child(4n+1),
    .source-card:nth-child(4n+1),
    .term-card:nth-child(4n+1),
    .check-card:nth-child(4n+1) {
      border-top: 5px solid var(--emerald);
    }

    .mini-card:nth-child(4n+2),
    .source-card:nth-child(4n+2),
    .term-card:nth-child(4n+2),
    .check-card:nth-child(4n+2) {
      border-top: 5px solid var(--saffron);
    }

    .mini-card:nth-child(4n+3),
    .source-card:nth-child(4n+3),
    .term-card:nth-child(4n+3),
    .check-card:nth-child(4n+3) {
      border-top: 5px solid var(--coral);
    }

    .mini-card:nth-child(4n+4),
    .source-card:nth-child(4n+4),
    .term-card:nth-child(4n+4),
    .check-card:nth-child(4n+4) {
      border-top: 5px solid var(--indigo);
    }

    .mini-card h4,
    .source-card h4,
    .term-card h4,
    .check-card h4 {
      margin-top: 0;
      margin-bottom: 7px;
      color: #214f58;
      font-size: 15.5px;
    }

    .mini-card p,
    .source-card p,
    .term-card p,
    .check-card p {
      margin-bottom: 0;
      color: #445660;
      font-size: 13.6px;
    }

    .quote-panel {
      margin: 16px 0;
      padding: 16px 18px;
      border: 1px solid #c4dedd;
      border-radius: 8px;
      background:
        linear-gradient(135deg, rgba(18, 114, 95, .18), transparent 46%),
        linear-gradient(180deg, #fff7db, #f5fcfb);
    }

    .quote-panel strong {
      color: #125a53;
    }

    .illustration {
      margin: 0;
    }

    .illustration svg {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 8px;
      border: 2px solid rgba(229, 170, 47, .42);
      background: #fff9ea;
      box-shadow: 0 10px 24px rgba(24, 35, 43, .08);
    }

    .small-ill svg {
      aspect-ratio: 500 / 330;
    }

    .wide-ill {
      margin: 14px 0 16px;
    }

    .wide-ill svg {
      aspect-ratio: 900 / 330;
    }

    .caption {
      margin-top: 6px;
      color: var(--muted);
      font-size: 12.2px;
      line-height: 1.45;
    }

    .callout-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 8px;
      margin: 16px 0;
    }

    .callout-strip div {
      min-height: 78px;
      padding: 10px 9px;
      border-radius: 8px;
      color: #fff;
      background: var(--emerald);
    }

    .callout-strip div:nth-child(2) {
      background: var(--indigo);
    }

    .callout-strip div:nth-child(3) {
      background: var(--coral);
    }

    .callout-strip div:nth-child(4) {
      background: var(--leaf);
    }

    .callout-strip strong {
      display: block;
      margin-bottom: 4px;
      font-size: 13px;
    }

    .callout-strip span {
      display: block;
      font-size: 12.2px;
      line-height: 1.4;
    }

    .timeline {
      margin: 16px 0;
      border-left: 4px solid var(--emerald);
    }

    .timeline-item {
      position: relative;
      padding: 0 0 14px 18px;
    }

    .timeline-item::before {
      content: "";
      position: absolute;
      top: 4px;
      left: -9px;
      width: 14px;
      height: 14px;
      border: 3px solid #fff;
      border-radius: 50%;
      background: var(--saffron);
      box-shadow: 0 0 0 2px var(--emerald);
    }

    .timeline-item h4 {
      margin: 0 0 4px;
      font-size: 15.7px;
      color: #17303b;
    }

    .timeline-item p {
      margin: 0;
      color: #43545d;
      font-size: 13.8px;
    }

    .matrix {
      display: grid;
      grid-template-columns: 29mm 1fr 1fr;
      margin: 14px 0;
      border: 1px solid var(--line);
      border-radius: 8px;
      overflow: hidden;
      font-size: 13.4px;
    }

    .matrix div {
      padding: 8px 9px;
      border-right: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      background: rgba(255,255,255,.56);
    }

    .matrix div:nth-child(3n) {
      border-right: 0;
    }

    .matrix .head {
      color: #163f3a;
      background: #e5f4ef;
      font-weight: 800;
    }

    .matrix .book {
      color: #163f3a;
      background: #fff1c7;
      font-weight: 850;
    }

    table {
      width: 100%;
      margin: 14px 0;
      border-collapse: collapse;
      font-size: 13.5px;
    }

    th,
    td {
      padding: 8px 9px;
      border: 1px solid var(--line);
      vertical-align: top;
    }

    th {
      background: #e6f5f1;
      color: #173b43;
      text-align: left;
    }

    ol,
    ul {
      margin-top: 7px;
      padding-left: 22px;
    }

    li {
      margin-bottom: 7px;
    }

    .bibliography li {
      margin-bottom: 8px;
    }

    .footer-note {
      margin-top: 16px;
      padding: 13px 15px;
      border-top: 3px solid var(--emerald);
      background: linear-gradient(135deg, #f5fbfb, #fff3df);
      color: #41525b;
      font-size: 13px;
    }

    .divider {
      width: 58px;
      height: 5px;
      margin: 10px 0 16px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--emerald), var(--saffron), var(--coral), var(--indigo));
    }

    .chapter-ribbon {
      display: inline-block;
      margin-bottom: 10px;
      padding: 5px 9px;
      border-radius: 4px;
      background: linear-gradient(90deg, #133d3a, var(--emerald), var(--indigo), var(--coral));
      color: #fff8e5;
      font-size: 11px;
      font-weight: 850;
      letter-spacing: .11em;
      text-transform: uppercase;
    }

    @media screen {
      body {
        padding: 18px;
      }

      .page,
      .chapter,
      .section-page {
        width: min(100%, 210mm);
        min-height: 297mm;
        margin: 0 auto 18px;
        padding: 17mm;
        background:
          linear-gradient(180deg, rgba(255, 254, 249, .97) 0%, rgba(255, 247, 230, .97) 100%);
        box-shadow: var(--shadow);
      }

      .cover {
        width: min(100%, 210mm);
        margin: 0 auto 18px;
        box-shadow: var(--shadow);
      }
    }

    @media (max-width: 760px) {
      body {
        padding: 0;
      }

      .page,
      .chapter,
      .section-page {
        width: 100%;
        min-height: auto;
        padding: 24px 18px;
        margin: 0;
        box-shadow: none;
      }

      .cover {
        width: 100%;
        min-height: 100vh;
        margin: 0;
        padding: 36px 20px 28px;
      }

      h1 {
        font-size: 39px;
      }

      h2 {
        font-size: 26px;
      }

      .chapter-head,
      .grid-two,
      .grid-three,
      .callout-strip {
        grid-template-columns: 1fr;
      }

      .cover-footer {
        flex-direction: column;
        align-items: start;
      }

      .book-mark {
        width: 100%;
      }

      .matrix {
        grid-template-columns: 1fr;
      }

      .matrix div {
        border-right: 0;
      }
    }
  </style>
</head>
<body>
  <section class="cover">
    <div class="cover-title">
      <div class="kicker">Buku Materi PAI</div>
      <h1>Beriman kepada Kitab-kitab Allah SWT</h1>
      <p class="subtitle">Mengenal wahyu Allah, kitab-kitab yang wajib diimani, dan cara menjadikan Al-Qur'an sebagai petunjuk hidup.</p>
      <div class="cover-badges">
        <span>Rukun iman ke-3</span>
        <span>Dalil ringkas</span>
        <span>Ilustrasi simbolik</span>
        <span>Siap cetak A4</span>
      </div>
    </div>

    <figure class="cover-art" aria-label="Ilustrasi simbolik kitab-kitab Allah">
      <svg viewBox="0 0 1100 650" role="img">
        <defs>
          <linearGradient id="coverSky" x1="0" x2="1" y1="0" y2="1">
            <stop offset="0" stop-color="#123f3c"/>
            <stop offset=".44" stop-color="#1c8a78"/>
            <stop offset=".45" stop-color="#efbf46"/>
            <stop offset=".63" stop-color="#f6de91"/>
            <stop offset=".64" stop-color="#46538b"/>
            <stop offset="1" stop-color="#162849"/>
          </linearGradient>
          <linearGradient id="bookGold" x1="0" x2="1">
            <stop offset="0" stop-color="#fff2be"/>
            <stop offset=".5" stop-color="#e7aa31"/>
            <stop offset="1" stop-color="#bf742a"/>
          </linearGradient>
          <pattern id="mosaic" width="44" height="44" patternUnits="userSpaceOnUse">
            <path d="M22 2 L42 22 L22 42 L2 22 Z" fill="none" stroke="#fff7d5" stroke-width="2" opacity=".35"/>
            <path d="M22 10 L34 22 L22 34 L10 22 Z" fill="none" stroke="#fff7d5" stroke-width="1.5" opacity=".35"/>
          </pattern>
        </defs>
        <rect width="1100" height="650" fill="url(#coverSky)"/>
        <rect width="1100" height="650" fill="url(#mosaic)" opacity=".72"/>
        <path d="M0 498 C141 435 269 458 396 410 C545 354 657 380 792 334 C895 299 998 289 1100 316 L1100 650 L0 650 Z" fill="#0d3535" opacity=".74"/>
        <path d="M0 566 C158 510 282 522 410 563 C573 616 724 597 890 535 C978 502 1047 498 1100 511 L1100 650 L0 650 Z" fill="#133149" opacity=".64"/>
        <circle cx="810" cy="118" r="56" fill="#f4c95e"/>
        <path d="M92 190 C148 156 207 158 255 194" fill="none" stroke="#fff5d1" stroke-width="9" stroke-linecap="round" opacity=".78"/>
